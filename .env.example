# Copy this to .env and fill in your values

PORT=3001
NODE_ENV=production

# REQUIRED: Change this to a long random string for security
JWT_SECRET=CHANGE_THIS_TO_RANDOM_STRING_MIN_32_CHARS

# OPTIONAL: Razorpay for ₹49/tenant billing
# Get keys from razorpay.com → Dashboard → Settings → API Keys
RAZORPAY_KEY_ID=rzp_live_YOUR_KEY_HERE
RAZORPAY_KEY_SECRET=YOUR_SECRET_HERE

# OPTIONAL: Where data is stored (Render persistent disk)
DATA_DIR=/var/data
